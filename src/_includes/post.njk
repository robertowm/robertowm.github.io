---
layout: layout.njk
---
<article class="post-content section">
    <header class="post-header">
        <h1>{{ title }}</h1>
        <p class="neon-text">{{ date | dateFilter }}</p>
    </header>

    <div class="markdown-body">
        {{ content | safe }}
    </div>

    <div class="post-footer">
        <a href="/">&larr; Back to Home</a>
    </div>
</article>
