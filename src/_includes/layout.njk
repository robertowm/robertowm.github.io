<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ profile.full_name }} | {{ title }}</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&display=swap" rel="stylesheet">
</head>
<body data-theme="brutalist-dark">
    <div class="top-controls">
        <button id="brutalist-toggle" class="icon-toggle" title="Toggle Dark/Light">
            <span class="sun-icon">☀️</span>
            <span class="moon-icon">🌙</span>
        </button>

        {% if env.isDev %}
        <div class="theme-switch-container">
            <label for="theme-select">Dev:</label>
            <select id="theme-select">
                <option value="default">Synthwave</option>
                <option value="doom">Doom</option>
                <option value="brutalist">Brutalist</option>
                <option value="brutalist-dark">Brutalist Dark</option>
                <option value="terminal">Terminal</option>
                <option value="glass">Glass</option>
            </select>
        </div>
        {% endif %}
    </div>
    <header>
        <div class="container">
            <h1>{{ profile.full_name }}</h1>
            <p class="neon-text">{{ profile.address }}</p>
        </div>
    </header>

    <main class="container">
        {{ content | safe }}
    </main>

    <footer>
        <div class="container">
            <p>&copy; {{ page.date.getFullYear() }} {{ profile.full_name }}</p>
            <p>Built with 11ty - Minimalist & Fast</p>
        </div>
    </footer>

    <script>
        const body = document.body;
        const brutalistToggle = document.getElementById('brutalist-toggle');
        const themeSelect = document.getElementById('theme-select');
        
        // Load preference
        const savedTheme = localStorage.getItem('theme') || 'brutalist-dark';
        body.setAttribute('data-theme', savedTheme);
        if (themeSelect) themeSelect.value = savedTheme;

        // Dark/Light Toggle Logic
        brutalistToggle.addEventListener('click', () => {
            const current = body.getAttribute('data-theme');
            let next;
            
            if (current === 'brutalist-dark') {
                next = 'brutalist';
            } else if (current === 'brutalist') {
                next = 'brutalist-dark';
            } else {
                // If in another theme, toggle to the opposite of current preference or just light
                next = current.includes('dark') || current === 'default' || current === 'doom' || current === 'terminal' || current === 'glass' ? 'brutalist' : 'brutalist-dark';
            }

            setTheme(next);
        });

        // Dev Select Logic
        if (themeSelect) {
            themeSelect.addEventListener('change', (e) => setTheme(e.target.value));
        }

        function setTheme(theme) {
            body.setAttribute('data-theme', theme);
            localStorage.setItem('theme', theme);
            if (themeSelect) themeSelect.value = theme;
        }
    </script>
</body>
</html>
