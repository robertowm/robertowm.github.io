<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ profile.full_name }} | {{ title }}</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <header>
        <div class="container">
            <h1>{{ profile.full_name }}</h1>
            <p class="neon-text">{{ profile.address }}</p>
        </div>
    </header>

    <main class="container">
        {{ content | safe }}
    </main>

    <footer>
        <div class="container">
            <p>&copy; {{ page.date.getFullYear() }} {{ profile.full_name }}</p>
            <p>Built with 11ty - Minimalist & Fast</p>
        </div>
    </footer>
</body>
</html>
