<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ profile.full_name }} | {{ title }}</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body data-theme="default">
    <button class="theme-switch" id="theme-toggle">Theme: Synth</button>
    <header>
        <div class="container">
            <h1>{{ profile.full_name }}</h1>
            <p class="neon-text">{{ profile.address }}</p>
        </div>
    </header>

    <main class="container">
        {{ content | safe }}
    </main>

    <footer>
        <div class="container">
            <p>&copy; {{ page.date.getFullYear() }} {{ profile.full_name }}</p>
            <p>Built with 11ty - Minimalist & Fast</p>
        </div>
    </footer>

    <script>
        const toggle = document.getElementById('theme-toggle');
        const body = document.body;
        
        // Load preference
        const savedTheme = localStorage.getItem('theme') || 'default';
        body.setAttribute('data-theme', savedTheme);
        updateButtonText(savedTheme);

        toggle.addEventListener('click', () => {
            const current = body.getAttribute('data-theme');
            const next = current === 'default' ? 'doom' : 'default';
            
            body.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
            updateButtonText(next);
        });

        function updateButtonText(theme) {
            toggle.innerText = theme === 'default' ? 'Theme: Synth' : 'Theme: Doom';
        }
    </script>
</body>
</html>
