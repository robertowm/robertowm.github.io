---
layout: layout.njk
title: Home
---

<section class="bio section">
    {% for paragraph in profile.bio %}
        <p>{{ paragraph }}</p>
    {% endfor %}
</section>

<section class="section">
    <h2>Work Experience</h2>
    {% for job in work %}
        <div class="card">
            <h3>{{ job.position }} @ <a href="{{ job.url }}">{{ job.company }}</a></h3>
            <p class="neon-text">{{ job.start_year }} - {{ job.end_year or "Present" }}</p>
            {% for p in job.summary %}
                <p>{{ p }}</p>
            {% endfor %}
        </div>
    {% endfor %}
</section>

<section class="section">
    <h2>Projects</h2>
    {% for project in projects %}
        <details class="project-details">
            <summary>
                <span class="project-title">{{ project.name }} ({{ project.year }})</span>
                <span class="project-company">{{ project.company }}</span>
            </summary>
            <div class="project-content">
                {% for p in project.content %}
                    <p>{{ p }}</p>
                {% endfor %}
                {% if project.url %}
                    <p><a href="{{ project.url }}" target="_blank">View Project &rarr;</a></p>
                {% endif %}
            </div>
        </details>
    {% endfor %}
</section>

<section class="section">
    <h2>Background</h2>
    <div class="background-grid">
        <div class="background-group">
            <h3>Education</h3>
            <ul class="minimal-list">
            {% for edu in qualifications.education %}
                <li><strong>{{ edu.title }}</strong>, {{ edu.institution }} ({{ edu.start_year }} - {{ edu.end_year }})</li>
            {% endfor %}
            </ul>
        </div>

        <div class="background-group">
            <h3>Certifications</h3>
            <ul class="minimal-list">
            {% for cert in qualifications.certifications %}
                <li><a href="{{ cert.url }}">{{ cert.name }}</a> - {{ cert.institutions | join(', ') }}</li>
            {% endfor %}
            </ul>
        </div>
    </div>
</section>
